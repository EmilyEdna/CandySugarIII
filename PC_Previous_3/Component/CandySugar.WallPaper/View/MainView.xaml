<UserControl
    x:Class="CandySugar.WallPaper.View.MainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:CandySugar.WallPaper.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:CandySugar.WallPaper.ViewModels"
    d:DataContext="{d:DesignInstance vm:MainViewModel}"
    d:DesignHeight="700"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:eda="https://github.com/EmilyEdna"
    d:DesignWidth="1200"
    mc:Ignorable="d">
    <eda:CandyTabControl ItemsSource="{Binding ComponentControl}"
                         IsEnableCloseButton="Collapsed">
        <hc:Interaction.Triggers>
            <hc:EventTrigger EventName="SelectionChanged">
                <hc:InvokeCommandAction Command="{Binding SelectCommand}" 
                                        CommandParameter="{Binding SelectedItem,RelativeSource={RelativeSource AncestorType=eda:CandyTabControl}}"/>
            </hc:EventTrigger>
        </hc:Interaction.Triggers>
        <eda:CandyTabControl.ItemTemplate>
            <DataTemplate>
                <TextBlock Text="{Binding Title}" Width="100"/>
            </DataTemplate>
        </eda:CandyTabControl.ItemTemplate>
        <eda:CandyTabControl.ContentTemplate>
            <DataTemplate>
                <ContentControl Content="{Binding Value}" Width="{Binding Width}"/>
            </DataTemplate>
        </eda:CandyTabControl.ContentTemplate>
    </eda:CandyTabControl>
</UserControl>
